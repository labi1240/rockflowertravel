# Copy to .env and fill in real values. NEVER put real secrets in this file.
DATABASE_URL=postgres://user:password@host:5432/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# UploadThing (CMS media hosting) — get these from https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=your-uploadthing-token-here
UPLOADTHING_SECRET_KEY=your-uploadthing-secret-key-here

# Stripe (payments)
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here

# Public site URL (used for canonical/OG URLs + sitemap)
NEXT_PUBLIC_SITE_URL=https://rockflowertravels.ca
